{
  "name": "eslint-config-kink",
  "version": "3.0.2",
  "description": "Kink.com ESLint standards",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "NODE_ENV=tester npx mocha --file test/support/setup.js \"test/**/*.test.js\"",
    "test:watch": "npm run test:unit -- --watch --watch-files src/**/*.js,test/**/*.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:rules": "eslint-find-rules",
    "lint:rules:fix": "eslint-find-rules --fix"
  },
  "dependencies": {
    "eslint": "^8.10.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "8.5.x",
    "eslint-plugin-compat": "^4.2.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.2.5",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-kink": "file:src",
    "eslint-plugin-mocha": "^6.3.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "4.x",
    "eslint-plugin-promise": "^4.3.1",
    "eslint-plugin-react": "^7.28.2",
    "eslint-plugin-react-hooks": "^4.3.0",
    "eslint-plugin-security": "^1.4.0",
    "eslint-plugin-unicorn": "^41.0.0",
    "eslint-plugin-vue": "^9.26.0",
    "eslint-plugin-you-dont-need-lodash-underscore": "^6.11.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.24.5",
    "chalk": "^4.1.0",
    "eslint-find-rules": "^4.1.0",
    "lodash": "^4.17.21",
    "minimist": "^1.2.6",
    "mocha": "^10.4.0",
    "package-json-validator": "0.6.x",
    "table": "^6.0.3"
  },
  "imports": {
    "#rules/*": "./src/lib/rules/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kink-Com/eslint-config-kink.git"
  },
  "keywords": [
    "eslint",
    "eslintconfig"
  ],
  "author": "Kink Developers <dev@kink.com>",
  "contributors": [
    {
      "name": "Jon Peck",
      "email": "jonpeck@kink.com"
    },
    {
      "name": "Bob Beban",
      "email": "bobbeban@kink.com"
    },
    {
      "name": "Tess Lins",
      "email": "tessbakke@kink.com"
    }
  ],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Kink-Com/eslint-config-kink/issues"
  },
  "homepage": "https://github.com/Kink-Com/eslint-config-kink#readme",
  "engines": {
    "node": ">=8.17"
  }
}
